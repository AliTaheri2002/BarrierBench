  "template_settings": {
    "_comment": "Template-specific configurations for 4 template types",
    "template_types": ["linear", "quadratic", "nonlinear", "polynomial"],
    "attempts_per_template": 4,
    "template_priorities": {
      "linear": 1,
      "quadratic": 2, 
      "nonlinear": 3,
      "polynomial": 4
    },
    "template_specifications": {
      "linear": {
        "structure": "a*x1 + b*x2 + c",
        "degree": 1,
        "parameters": ["a", "b", "c"],
        "default_values": [2.0, 1.5, -0.8],
        "use_cases": ["Linear systems", "Simple separation"]
      },
      "quadratic": {
        "structure": "a*x1**2 + b*x1*x2 + c*x2**2 + d*x1 + e*x2 + f",
        "degree": 2,
        "parameters": ["a", "b", "c", "d", "e", "f"],
        "default_values": [1.5, 0.2, 1.0, 0.0, 0.0, -1.2],
        "use_cases": ["Linear systems", "Mild nonlinearities", "Elliptical boundaries"]
      },
      "nonlinear": {
        "structure": "a*x1**2 + b*x2**2 + c",
        "degree": 2,
        "parameters": ["a", "b", "c"],
        "default_values": [1.2, 1.0, -1.1],
        "use_cases": ["Nonlinear systems", "Circular boundaries"]
      },
      "polynomial": {
        "structure": "a*x1**4 + b*x2**4 + c*x1**2 + d*x2**2 + e*x1*x2 + f",
        "degree": 4,
        "parameters": ["a", "b", "c", "d", "e", "f"],
        "default_values": [0.5, 0.3, 1.1, 0.9, 0.1, -2.1],
        "use_cases": ["High-degree nonlinear", "Complex boundaries"]
      }
    }
  },
  
  "problem_templates": {
    "_comment": "Pre-defined problem templates for common scenarios",
    "linear_2d_stable": {
      "dynamics": "dx1/dt = -x1 + 0.5*x2, dx2/dt = -x2 - 0.3*x1",
      "initial_set": {"type": "ball", "radius": 0.5, "center": [0, 0]},
      "unsafe_set": {"type": "ball", "radius": 3.0, "center": [0, 0], "complement": true},
      "recommended_template": "quadratic",
      "expected_result": "1.5*x1**2 + 0.2*x1*x2 + 1.0*x2**2 - 1.2"
    },
    "nonlinear_2d": {
      "dynamics": "dx1/dt = x2, dx2/dt = -x1 + x1^3 - 0.1*x2",
      "initial_set": {"type": "box", "bounds": [[-0.5, 0.5], [-0.5, 0.5]]},
      "unsafe_set": {"type": "union", "sets": [
        {"type": "halfspace", "a": [1, 0], "b": 2},
        {"type": "halfspace", "a": [-1, 0], "b": 2}
      ]},
      "recommended_template": "polynomial",
      "expected_result": "0.5*x1**4 + 0.3*x2**4 + 1.1*x1**2 + 0.9*x2**2 - 2.1"
    }
  },
  
