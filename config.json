  "synthesis_settings": {
    "_comment": "Barrier certificate synthesis specific settings - NUMERICAL FOCUS",
    "max_synthesis_iterations": 3,
    "condition_tolerance": 1e-6,
    "sampling_points_per_condition": 200,
    "zero_level_set_tolerance": 0.2,
    "force_numerical_parameters": true,
    "reject_symbolic_parameters": true,
    "numerical_parameter_defaults": {
      "linear": {
        "a": 2.0,
